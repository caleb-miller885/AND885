<?xml version="1.0" encoding="utf-8"?>
<!-- Single UAS row: colored left strip + drone icon + callsign/details + badge + timestamp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:background="@color/cuas_card_bg"
    android:layout_marginBottom="1dp">

    <!-- Threat-level color strip (color set programmatically) -->
    <View
        android:id="@+id/threat_strip"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="@color/threat_unknown" />

    <!-- Row content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Primary row: icon  callsign  [CLASSIFICATION] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/item_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_drone"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_callsign"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CALLSIGN"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Classification badge (background set programmatically) -->
            <TextView
                android:id="@+id/tv_classification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNKNOWN"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Secondary row: type/alt/speed  timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_details"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Unknown  •  Alt: —  •  Spd: —"
                android:textColor="@color/cuas_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--:--"
                android:textColor="@color/cuas_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
