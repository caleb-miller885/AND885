<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@color/cuas_surface_alt"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_sensor"
        android:tint="@color/cuas_text_secondary"
        android:layout_marginEnd="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_sensor_callsign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SENSOR"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_sensor_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/cuas_text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/tv_sensor_fov"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOV —°"
            android:textColor="@color/cuas_text_secondary"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tv_sensor_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RNG — m"
            android:textColor="@color/cuas_text_secondary"
            android:textSize="9sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/btn_sensor_visibility"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HIDE"
        android:textSize="9sp"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
