<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cuas_card_bg" />
            <corners android:radius="4dp" />
            <stroke
                android:width="1dp"
                android:color="@color/cuas_divider" />
        </shape>
    </item>
    <item
        android:width="16dp"
        android:height="16dp"
        android:gravity="end|center_vertical"
        android:right="8dp"
        android:drawable="@drawable/platform_dropdown_arrow" />
</layer-list>
